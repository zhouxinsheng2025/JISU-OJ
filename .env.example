# JISU裁判系统 配置文件
# 复制为 .env 并修改

# ── 数据库 ──
# 开发: SQLite (默认)
DATABASE_URL=sqlite+aiosqlite:///judge.db
# 生产: PostgreSQL (支持高并发写入)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/judge

# ── 连接池 (仅 PostgreSQL 生效) ──
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10

# ── JWT 密钥 (生产务必修改!) ──
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# ── 判题引擎 ──
# 并行判题 worker 数量 (建议 = CPU 核数)
JUDGE_WORKERS=3
JUDGE_POLL_INTERVAL=0.5

# ── 编译限制 ──
COMPILE_TIME_LIMIT=30

# ── 管理员 ──
# 首次启动时若未配置密码，系统会随机生成并打印到控制台
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-password

# ── 运行模式 ──
# 生产环境设为 true（关闭 /docs、收紧安全策略）
PRODUCTION=false
LOG_LEVEL=INFO
# LOG_FILE=server.log
